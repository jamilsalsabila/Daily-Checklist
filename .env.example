# SMTP configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USERNAME=your_account@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_account@gmail.com
SMTP_FROM_NAME=Daily Checklist

# Admin login (best practice: use password hash, not plain password)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2y$10$replace_this_with_password_hash
# Optional fallback (not recommended):
# ADMIN_PASSWORD=your_plain_password
